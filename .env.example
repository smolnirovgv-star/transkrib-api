# Anthropic API key for Claude analysis
APP_ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Whisper model: tiny, base, small, medium, large
APP_WHISPER_MODEL=small

# Claude model
APP_CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Redis (Celery broker)
APP_CELERY_BROKER_URL=redis://localhost:6379/0
APP_CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Storage directory (absolute path)
# APP_STORAGE_DIR=/app/storage

# FFmpeg path (auto-detect if empty)
# APP_FFMPEG_PATH=

# Server
APP_CORS_ORIGINS=["*"]
APP_MAX_UPLOAD_SIZE_MB=2048
