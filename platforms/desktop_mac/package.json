{
  "name": "transkrib-mac",
  "version": "1.0.1",
  "description": "Transkrib Desktop - macOS Electron App",
  "main": "dist/main/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/smolnirovgv-star/transkrib-api.git"
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"tsc -p tsconfig.main.json --watch\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "build:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.1",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "extends": "electron-builder.yml"
  },
  "author": "Transkrib SmartCut AI"
}
